r gap-x-1.5 gap-y-1 font-heading font-normal tracking-tight text-[#252830] md:mb-9 md:gap-x-2.5\"><span class=\"text-[2.1rem] leading-none sm:text-4xl md:text-5xl lg:text-6xl\">Elias</span><span class=\"mx-0.5 translate-y-[0.02em] font-heading text-[2.35rem] font-light italic leading-none sm:text-[2.85rem] md:text-[3.75rem] lg:text-[4.25rem]\">&amp;</span><span class=\"text-[2.1rem] leading-none sm:text-4xl md:text-5xl lg:text-6xl\">Saron</span></h1><div class=\"mb-2.5 inline-flex items-center justify-center gap-4 rounded-full border border-white/70 bg-white/55 px-6 py-3 shadow-[0_8px_32px_rgba(0,0,0,0.06)] backdrop-blur-md md:gap-8 md:px-10 md:py-4\" style=\"opacity:0;transform:translateY(10px)\"><span class=\"font-heading text-sm font-light italic text-[#252830]/55 md:text-base\">April</span><div class=\"flex min-w-[2.65rem] flex-col items-center md:min-w-[3.25rem]\"><span class=\"font-heading text-[2.35rem] font-semibold leading-[0.85] text-[#252830] md:text-5xl lg:text-6xl\">25</span><span class=\"mt-0.5 font-heading text-[6px] font-normal uppercase tracking-[0.22em] text-[#252830]/45 md:text-[8px]\">Sat</span></div><span class=\"font-heading text-sm font-light italic text-[#252830]/55 md:text-base\">2026</span></div><p class=\"mb-6 font-heading text-sm font-light text-[#252830]/75 md:text-base\" style=\"opacity:0\">3:00 PM</p><p class=\"mb-2.5 font-body text-[9px] font-medium uppercase tracking-[0.34em] text-[#252830]/80 md:text-[11px] md:tracking-[0.4em]\" style=\"opacity:0\">We are getting married</p><p class=\"font-heading text-xs font-light italic text-[#252830]/60 md:text-sm\" style=\"opacity:0\">Addis Ababa, Ethiopia</p></div></div><div class=\"fixed bottom-8 right-8 z-50 group\" style=\"opacity:0;transform:translateY(20px)\"><div class=\"flex items-center gap-3 bg-cream/80 backdrop-blur-md px-4 py-2 rounded-full border border-accent/20 shadow-lg group-hover:border-accent/40 transition-all duration-300\"><span class=\"text-xs font-body tracking-wider text-sepia/60 uppercase group-hover:text-sepia transition-colors\">Our Song</span><button class=\"w-10 h-10 flex items-center justify-center rounded-full bg-accent text-cream hover:scale-105 active:scale-95 transition-all shadow-md\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"currentColor\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-play ml-0.5\" aria-hidden=\"true\"><path d=\"M5 5a2 2 0 0 1 3.008-1.728l11.997 6.998a2 2 0 0 1 .003 3.458l-12 7A2 2 0 0 1 5 19z\"></path></svg></button></div><audio loop=\"\" src=\"/assets/mp3/koka%20-%20elelta%202026-04-06%2015_16.m4a\"></audio></div><div class=\"pointer-events-none absolute bottom-3 left-1/2 flex -translate-x-1/2 flex-col items-center md:bottom-5\" style=\"opacity:0\"><div class=\"h-7 w-[1.5px] rounded-full bg-gradient-to-b from-gold/60 to-transparent md:h-9\"></div></div></section><section class=\"py-20 bg-off-white relative overflow-hidden\"><div class=\"absolute top-0 left-0 w-64 h-64 bg-accent/5 rounded-full -translate-x-1/2 -translate-y-1/2 blur-3xl\"></div><div class=\"absolute bottom-0 right-0 w-64 h-64 bg-gold/5 rounded-full translate-x-1/2 translate-y-1/2 blur-3xl\"></div><div class=\"container mx-auto px-4 relative z-10 text-center\"><div class=\"mb-10\" style=\"opacity:0;transform:translateY(20px)\"><span class=\"text-accent uppercase tracking-[0.4em] text-[10px] font-bold mb-4 block\">The Final Countdown</span><h2 class=\"text-4xl md:text-5xl font-heading text-sepia mb-4\">Can&#x27;t Wait to<!-- --> <span class=\"text-gold italic font-serif\">Celebrate</span> <!-- -->with You</h2><p class=\"text-sepia/60 font-body text-sm uppercase tracking-widest\">Gathering in Addis Ababa • April 25, 2026</p></div><div style=\"opacity:0;transform:scale(0.95)\"></div><p class=\"mt-12 text-accent/40 font-body text-xs uppercase tracking-[0.6em] italic\" style=\"opacity:0\">Until we become one</p><div class=\"mt-10 max-w-3xl mx-auto\" style=\"opacity:0;transform:translateY(12px)\"><p class=\"font-body text-lg text-sepia/80 italic leading-relaxed\">&quot;ቸር ነውና፥ ምሕረቱ ለዘላለም ነውና፡ እግዚአብሔርን አመስግኑ፤&quot;</p><p class=\"font-body text-md text-sepia/60 mt-2\">Psalms 107:1 - &quot;Give thanks to the Lord, for he is good; his love endures forever.&quot;</p></div></div></section><section id=\"story\" class=\"py-24 overflow-hidden\"><div class=\"container mx-auto px-4\"><div class=\"text-center mb-20\" style=\"opacity:0;transform:translateY(20px)\"><h2 class=\"text-4xl md:text-6xl font-heading text-sepia mb-4\">Our Story</h2><div class=\"flex items-center justify-center gap-4\"><div class=\"h-[1px] w-12 bg-accent/40\"></div><span class=\"text-accent font-body uppercase tracking-[0.2em] text-sm font-bold\">Journey Together</span><div class=\"h-[1px] w-12 bg-accent/40\"></div></div></div><div class=\"relative\"><div class=\"absolute left-1/2 top-0 bottom-0 w-[1px] bg-accent/20 hidden md:block\"></div><div class=\"flex flex-col md:flex-row items-center mb-24 last:mb-0 \"><div class=\"w-full md:w-1/2 px-8 mb-8 md:mb-0\"><div class=\"relative aspect-[4/3] overflow-hidden rounded-sm shadow-xl\" style=\"opacity:0;transform:translateX(-50px)\"><img alt=\"The First Meeting\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover hover:scale-105 transition-transform duration-700\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"100vw\" srcSet=\"/_next/image?url=%2Fassets%2Fimages%2Four-story%2Fphoto_2026-04-03_10-41-37.jpg&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fassets%2Fimages%2Four-story%2Fphoto_2026-04-03_10-41-37.jpg&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fassets%2Fimages%2Four-story%2Fphoto_2026-04-03_10-41-37.jpg&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fassets%2Fimages%2Four-story%2Fphoto_2026-04-03_10-41-37.jpg&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fassets%2Fimages%2Four-story%2Fphoto_2026-04-03_10-41-37.jpg&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fassets%2Fimages%2Four-story%2Fphoto_2026-04-03_10-41-37.jpg&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fassets%2Fimages%2Four-story%2Fphoto_2026-04-03_10-41-37.jpg&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fassets%2Fimages%2Four-story%2Fphoto_2026-04-03_10-41-37.jpg&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2Fassets%2Fimages%2Four-story%2Fphoto_2026-04-03_10-41-37.jpg&amp;w=3840&amp;q=75\"/><div class=\"absolute inset-0 ring-1 ring-inset ring-accent/10\"></div></div></div><div class=\"w-full md:w-1/2 px-8 flex flex-col justify-center text-center md:text-left\"><div class=\"md:pl-12\" style=\"opacity:0;transform:translateY(20px)\"><span class=\"text-accent font-serif italic text-xl mb-2 block\">March 6 2025</span><h3 class=\"text-3xl font-heading text-sepia mb-4\">The First Meeting</h3><p class=\"text-sepia/70 font-body leading-relaxed max-w-md mx-auto md:mx-0\">In the heart of Addis Ababa, where coffee and conversation spark a lifelong journey, our first meeting took place within the quiet grace of a church where faith, chance, and destiny gently intertwined.</p></div></div><div class=\"absolute left-1/2 -ml-2 w-4 h-4 rounded-full bg-off-white border-2 border-accent hidden md:block\"></div></div><div class=\"flex flex-col md:flex-row items-center mb-24 last:mb-0 md:flex-row-reverse\"><div class=\"w-full md:w-1/2 px-8 mb-8 md:mb-0\"><div class=\"relative aspect-[4/3] overflow-hidden rounded-sm shadow-xl\" style=\"opacity:0;transform:translateX(50px)\"><img alt=\"Our Forever Begins\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover hover:scale-105 transition-transform duration-700\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"100vw\" srcSet=\"/_next/image?url=%2Fassets%2Fimages%2Fmemories%2FDSC00296.jpg&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fassets%2Fimages%2Fmemories%2FDSC00296.jpg